using System.Drawing.Printing;
using System.Runtime.InteropServices;
namespace Branch_Printing_APP.PrintManager
{
    public class CRTFPrinter
    {
        private RichTextBoxPrintCtrl oRichTextBoxPrintCtrl;
        private string sTextRTF = string.Empty;
        private bool bInitSuccess = false;
        private PrintDocument oPD;
        private int checkPrint = 0;

        public ComboBox cmbPrinters = new ComboBox();

        #region Structures

        public struct DOCINFO
        {
            public string pDocName;

            [MarshalAs(UnmanagedType.LPWStr)]
            public string pOutputFile;

            [MarshalAs(UnmanagedType.LPWStr)]
            public string pDataType;
        }

        public struct SPageSettings
        {
            public int Orientation;
        }

        #endregion

        #region Fields / Properties

        public IntPtr hPrinter1;
        public SPageSettings PrinterObject;
        public DOCINFO docinfo1;

        public string TextRTF
        {
            get => sTextRTF;
            set
            {
                sTextRTF = value;
                if (oRichTextBoxPrintCtrl != null)
                    oRichTextBoxPrintCtrl.Text = sTextRTF;
            }
        }

        #endregion

        #region DLL Imports

        [DllImport("winspool.drv", CharSet = CharSet.Unicode)]
        public static extern long OpenPrinter(string pPrinterName, ref IntPtr phPrinter, int pDefault);

        [DllImport("winspool.drv", CharSet = CharSet.Unicode)]
        public static extern long StartDocPrinter(IntPtr hPrinter, int Level, ref DOCINFO pDocInfo);

        [DllImport("winspool.drv")]
        public static extern long StartPagePrinter(IntPtr hPrinter);

        [DllImport("winspool.drv", CharSet = CharSet.Ansi)]
        public static extern long WritePrinter(IntPtr hPrinter, string data, int buf, ref int pcWritten);

        [DllImport("winspool.drv")]
        public static extern long EndPagePrinter(IntPtr hPrinter);

        [DllImport("winspool.drv")]
        public static extern long EndDocPrinter(IntPtr hPrinter);

        [DllImport("winspool.drv")]
        public static extern long ClosePrinter(IntPtr hPrinter);

        [DllImport("FINDFT.dll")]
        private static extern int rcptrn(
            string ibr, string ibrnm, string itele, string idate,
            string pname, string dbr, string dbrnm, string dftnum,
            string amnt, string srl, string code, string tel, string qnm);

        [DllImport("DDWithAdvice.dll")]
        private static extern int rcptrnadv(
            string ibr, string ibrnm, string itele, string idate,
            string pname, string dbr, string dbrnm, string dftnum,
            string amnt, string srl, string code, string tel, string qnm,
            string sCustCode, string sCustAddress1, string sCustAddress2,
            string sCustAddress3, string sCustAddress4, string sCustAddress5,
            string sRefNo, string Amount, string Name, string sRemitterName);

        #endregion

        #region Constructor / Init

        public CRTFPrinter()
        {
            InitializePrinterObjects();
        }

        public void PrinterSetting()
        {
            InitializePrinterObjects();
        }

        private void InitializePrinterObjects()
        {
            try
            {
                oPD = new PrintDocument();
                oPD.PrinterSettings = new PrinterSettings();

                oRichTextBoxPrintCtrl = new RichTextBoxPrintCtrl();

                PrinterObject = new SPageSettings { Orientation = 1 };

                oPD.DefaultPageSettings.Landscape = false;

                oPD.BeginPrint += opd_BeginPrint;
                oPD.PrintPage += opd_PrintPage;

                bInitSuccess = true;
            }
            catch (Exception ex)
            {
                bInitSuccess = false;
                throw new Exception(ex.Message);
            }
            finally
            {
                if (!bInitSuccess)
                {
                    oPD?.Dispose();
                    oRichTextBoxPrintCtrl?.Dispose();
                }
            }
        }

        #endregion

        #region Printer Commands

        public void StartPrinterCmd()
        {
            docinfo1.pDocName = "Test";
            docinfo1.pOutputFile = null;
            docinfo1.pDataType = null;

            StartDocPrinter(hPrinter1, 1, ref docinfo1);
            StartPagePrinter(hPrinter1);
        }

        public void EndPrinterCmd()
        {
            EndPagePrinter(hPrinter1);
            EndDocPrinter(hPrinter1);
            ClosePrinter(hPrinter1);
        }

        public void ResetPrinter()
        {
            int written = 0;
            StartPrinterCmd();

            string esc = ((char)18).ToString();
            WritePrinter(hPrinter1, esc, esc.Length, ref written);

            EndPrinterCmd();
        }

        #endregion

        #region Draft Printing

        public void PrintDraft(string ibr, string ibrnm, string itele, string idate,
            string pname, string dbr, string dbrnm, string dftnum,
            string amnt, string srl, string code, string tel, string qnm)
        {
            rcptrn(ibr, ibrnm, itele, idate, pname, dbr, dbrnm, dftnum, amnt, srl, code, tel, qnm);
        }

        public void PrintAdviseDraft(string ibr, string ibrnm, string itele, string idate,
            string pname, string dbr, string dbrnm, string dftnum,
            string amnt, string srl, string code, string tel, string qnm,
            string sCustCode, string sCustAddress1, string sCustAddress2,
            string sCustAddress3, string sCustAddress4, string sCustAddress5,
            string sRefNo, string amt, string Name, string sRemitterName)
        {
            rcptrnadv(ibr, ibrnm, itele, idate, pname, dbr, dbrnm, dftnum,
                amnt, srl, code, tel, qnm, sCustCode,
                sCustAddress1, sCustAddress2, sCustAddress3,
                sCustAddress4, sCustAddress5, sRefNo,
                amt, Name, sRemitterName);
        }

        #endregion

        #region Printer Initialization

        public void InitialisePrinter(string sPrinterName)
        {
            try
            {
                string[] sCommands = sPrinterName.Split(';');
                sPrinterName = sCommands[0];

                oPD.PrinterSettings.PrinterName = sPrinterName;

                if (OpenPrinter(sPrinterName, ref hPrinter1, 0) != 0)
                {
                    StartPrinterCmd();

                    int written = 0;

                    if (sCommands.Length > 1)
                    {
                        if (sCommands[1] == "17")
                        {
                            SendEscSequence(ref written, 18, 15);
                            ApplyPageSettings("LedgerForm", 1700, 1100);
                        }
                        else if (sCommands[1] == "12")
                        {
                            SendEscSequence(ref written, 18);
                            WritePrinter(hPrinter1, ((char)27).ToString() + ((char)58), 2, ref written);
                            ApplyPageSettings("LetterForm", 1100, 850);
                        }
                    }

                    SetZeroMargins();

                    EndPrinterCmd();
                }
            }
            catch { }
        }

        private void SendEscSequence(ref int written, params int[] chars)
        {
            foreach (var c in chars)
            {
                string seq = ((char)c).ToString();
                WritePrinter(hPrinter1, seq, seq.Length, ref written);
            }
        }

        private void ApplyPageSettings(string name, int width, int height)
        {
            PrinterObject.Orientation = 2;

            var size = new PaperSize(name, width, height);

            oPD.PrinterSettings.DefaultPageSettings.PaperSize = size;
            oPD.DefaultPageSettings.PaperSize = size;

            SetZeroMargins();
        }

        private void SetZeroMargins()
        {
            var m = new Margins(0, 0, 0, 0);
            oPD.PrinterSettings.DefaultPageSettings.Margins = m;
            oPD.DefaultPageSettings.Margins = m;
        }

        #endregion

        #region RTF Printing

        public void LoadFile(string path, string fileType = "")
        {
            if (string.IsNullOrEmpty(fileType))
                oRichTextBoxPrintCtrl.LoadFile(path);
            else
                oRichTextBoxPrintCtrl.LoadFile(path, RichTextBoxStreamType.RichText);
        }

        public void printRtf()
        {
            oPD.DefaultPageSettings.Landscape = (PrinterObject.Orientation != 1);

            if (PrinterObject.Orientation == 2)
            {
                foreach (PaperSize ps in oPD.PrinterSettings.PaperSizes)
                {
                    if (ps.Kind == PaperKind.A4)
                        oPD.DefaultPageSettings.PaperSize = ps;
                }

                SetZeroMargins();
            }
            else
            {
                var size = new PaperSize("BPA", 827, 1169);

                oPD.PrinterSettings.DefaultPageSettings.PaperSize = size;
                oPD.DefaultPageSettings.PaperSize = size;

                SetZeroMargins();
            }

            oPD.Print();
        }

        #endregion

        #region Events

        private void opd_BeginPrint(object sender, PrintEventArgs e)
        {
            StartPrinterCmd();
            checkPrint = 0;
        }

        private void opd_PrintPage(object sender, PrintPageEventArgs e)
        {
            try
            {
                if (oPD.DefaultPageSettings.PaperSize.PaperName == "LedgerForm")
                {
                    oRichTextBoxPrintCtrl.Text = oRichTextBoxPrintCtrl.Text.Trim();
                }

                checkPrint = oRichTextBoxPrintCtrl.Print(
                    checkPrint,
                    oRichTextBoxPrintCtrl.TextLength,
                    e);

                e.HasMorePages = checkPrint < oRichTextBoxPrintCtrl.TextLength;
            }
            catch { }
        }

        #endregion
    }
}
using System.Drawing.Printing;
using System.Runtime.InteropServices;
namespace Branch_Printing_APP.PrintManager
{
    public class RichTextBoxPrintCtrl : RichTextBox
    {
        private const double AnInch = 14.4;

        // =========================
        // STRUCTS (VB SAME)
        // =========================
        [StructLayout(LayoutKind.Sequential)]
        private struct RECT
        {
            public int Left;
            public int Top;
            public int Right;
            public int Bottom;
        }

        [StructLayout(LayoutKind.Sequential)]
        private struct CHARRANGE
        {
            public int cpMin;
            public int cpMax;
        }

        [StructLayout(LayoutKind.Sequential)]
        private struct FORMATRANGE
        {
            public IntPtr hdc;
            public IntPtr hdcTarget;
            public RECT rc;
            public RECT rcPage;
            public CHARRANGE chrg;
        }

        private const int WM_USER = 0x400;
        private const int EM_FORMATRANGE = WM_USER + 57;

        // =========================
        // WIN32 CALL (VB SAME)
        // =========================
        [DllImport("USER32.dll", CharSet = CharSet.Auto)]
        private static extern IntPtr SendMessage(
      IntPtr hWnd,
      int msg,
      IntPtr wParam,
      IntPtr lParam
    );

        // =========================
        // PRINT METHOD (EXACT)
        // =========================
        public int Print(int charFrom, int charTo, PrintPageEventArgs e)
        {
            try
            {
                // Character range
                CHARRANGE cRange = new CHARRANGE
                {
                    cpMin = charFrom,
                    cpMax = charTo
                };

                // Area to print
                RECT rectToPrint = new RECT
                {
                    Top = (int)(e.MarginBounds.Top * AnInch),
                    Bottom = (int)(e.MarginBounds.Bottom * AnInch),
                    Left = (int)(e.MarginBounds.Left * AnInch),
                    Right = (int)(e.MarginBounds.Right * AnInch)
                };

                // Full page
                RECT rectPage = new RECT
                {
                    Top = (int)(e.PageBounds.Top * AnInch),
                    Bottom = (int)(e.PageBounds.Bottom * AnInch),
                    Left = (int)(e.PageBounds.Left * AnInch),
                    Right = (int)(e.PageBounds.Right * AnInch)
                };

                IntPtr hdc = e.Graphics.GetHdc();

                FORMATRANGE fmtRange = new FORMATRANGE
                {
                    chrg = cRange,
                    hdc = hdc,
                    hdcTarget = hdc,
                    rc = rectToPrint,
                    rcPage = rectPage
                };

                IntPtr lparam = Marshal.AllocCoTaskMem(Marshal.SizeOf(typeof(FORMATRANGE)));
                Marshal.StructureToPtr(fmtRange, lparam, false);

                IntPtr wparam = new IntPtr(1);

                IntPtr res = SendMessage(this.Handle, EM_FORMATRANGE, wparam, lparam);

                Marshal.FreeCoTaskMem(lparam);
                e.Graphics.ReleaseHdc(hdc);

                return res.ToInt32();
            }
            catch
            {
                return 0;
            }
        }
    }
}
