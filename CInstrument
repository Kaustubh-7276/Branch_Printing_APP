    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: pdoc_PrintPage
    '   DESCRIPTION: Event handler for handling the PrintPage event of pdoc(pdoc is an object of type PrintDocument)
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. sender: Event Handler parameter
    '               2. e: Event handler parameter
    '*****************************************************************************************
    Private Sub pdoc_PrintPage(ByVal sender As Object, ByVal e As System.Drawing.Printing.PrintPageEventArgs) Handles m_pdoc.PrintPage
        ' Declare a variable to hold the position of the last printed char. Declare
        ' as static so that subsequent PrintPage events can reference it.
        Static intCurrentChar As Int32

        Dim intPrintAreaHeight, intPrintAreaWidth, marginLeft, marginTop As Int32
        Dim IOIPaperSize As PaperSize

        IOIPaperSize = New PaperSize("SBI IOI Paper Size", "800", "350")

        With m_pdoc.DefaultPageSettings
            ' Initialize local variables that contain the bounds of the printing 
            ' area rectangle.
            '.PrinterSettings.DefaultPageSettings.PaperSize = IOIPaperSize
            '.PaperSize = IOIPaperSize
            intPrintAreaHeight = .PaperSize.Height - .Margins.Top - .Margins.Bottom
            intPrintAreaWidth = .PaperSize.Width - .Margins.Left - .Margins.Right
            
            ' Initialize local variables to hold margin values that will serve
            ' as the X and Y coordinates for the upper left corner of the printing 
            ' area rectangle.
            marginLeft = .Margins.Left ' X coordinate
            marginTop = .Margins.Top ' Y coordinate
        End With
            
        ' If the user selected Landscape mode, swap the printing area height 
        ' and width.
        If m_pdoc.DefaultPageSettings.Landscape Then
            Dim intTemp As Int32
            intTemp = intPrintAreaHeight
            intPrintAreaHeight = intPrintAreaWidth
            intPrintAreaWidth = intTemp
        End If

        ' Calculate the total number of lines in the document based on the height of
        ' the printing area and the height of the font.
        ' Initialize the rectangle structure that defines the printing area.
        Dim rectPrintingArea As New RectangleF(marginLeft, marginTop, intPrintAreaWidth, intPrintAreaHeight)

        Dim IItem As CInstrumentItem
        For Each IItem In m_InstrumentItems
            PrintInstrumentItem(IItem, sender, e)
        Next

        ' For printing the vertical box
        'PrintVerticalBox(sender, e)
        e.HasMorePages = False
        ' You must explicitly reset intCurrentChar as it is static.
        intCurrentChar = 0
    End Sub

    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: PrintInstrumentItem
    '   DESCRIPTION: Used for processing an individual CInstrumentItem object
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. InstItem: CInstrumentItem : The CInstrumentItem object that needs to be processed for printing
    '               2. sender: pdoc_PrintPage eventhandler parameter. Not used currently. May be used in the future
    '               3. e: Handle needed for printing 
    '*****************************************************************************************
    Private Sub PrintInstrumentItem(ByVal InstItem As CInstrumentItem, ByVal sender As Object, ByVal e As System.Drawing.Printing.PrintPageEventArgs)
        ' If the item requires boxes then print boxes
        If InstItem.isInBox Then
            PrintBoxedItem(InstItem, sender, e)
        Else ' else print the item directly
            PrintUnboxedItem(InstItem, sender, e)
        End If
    End Sub

    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: PrintUnboxedItem
    '   DESCRIPTION: Sub to print items directly without any boxes
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. IItem: CInstrumentItem : The CInstrumentItem object that needs to be processed for printing
    '               2. sender: pdoc_PrintPage eventhandler parameter. Not used currently. May be used in the future
    '               3. e: Handle needed for printing 
    '*****************************************************************************************
    Private Sub PrintUnboxedItem(ByVal IItem As CInstrumentItem, ByVal sender As Object, ByVal e As System.Drawing.Printing.PrintPageEventArgs)
        e.Graphics.DrawString(IItem.Data, IItem.ItemFont, Brushes.Black, IItem.xPos, IItem.yPos)
    End Sub

    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: PrintBoxedItem
    '   DESCRIPTION: Sub to print items in boxes
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. IItem: CInstrumentItem : The CInstrumentItem object that needs to be processed for printing
    '               2. sender: pdoc_PrintPage eventhandler parameter. Not used currently. May be used in the future
    '               3. e: Handle needed for printing 
    '*****************************************************************************************

    Private Sub PrintBoxedItem(ByVal IItem As CInstrumentItem, ByVal sender As Object, ByVal e As System.Drawing.Printing.PrintPageEventArgs)
        Dim strValues As String()
        ' If item has digits and every digit needs to be in a separate box then
        If IItem.isDigit Then
            'Print the digits in individual boxes
            PrintDigits(IItem, sender, e)
'Start of ir 72595
        ElseIf IItem.isNoBoxLine Then
            PrintBoxedWithoutLines(IItem, sender, e)
'end of ir 72595
        Else ' If item just has an entire string to be boxed then
            ' If its an amount value to be converted to string then convert numbers to strings and print them in a rectangle
            If IItem.isAmount = True Then
                PrintAmountString(IItem, sender, e)
            Else ' If its a regular string to be printed
                ReDim strValues(0)
                strValues(0) = IItem.Data
                DrawBoxedString(sender, e, 1, IItem.xPos, IItem.yPos, IItem.BoxWidth, IItem.BoxHeight, strValues, IItem.ItemFont, IItem.xOffset, IItem.yOffset)
            End If
        End If
    End Sub
    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: PrintDigits
    '   DESCRIPTION: Sub to print items containing numeric data and requiring every digit to be printed in a separate box
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. IItem: CInstrumentItem : The CInstrumentItem object that needs to be processed for printing
    '               2. sender: pdoc_PrintPage eventhandler parameter. Not used currently. May be used in the future
    '               3. e: Handle needed for printing 
    '*****************************************************************************************

    Private Sub PrintDigits(ByVal IItem As CInstrumentItem, ByVal sender As Object, ByVal e As System.Drawing.Printing.PrintPageEventArgs)
        Dim chrValues As Char()
        Dim strValues As String()
        Dim i As Integer
        'Split the digits into a char array and then into a string array
        chrValues = IItem.Data.ToCharArray
        If IsArray(chrValues) Then
            ReDim strValues(UBound(chrValues))
            For i = LBound(chrValues) To UBound(chrValues)
                strValues(i) = chrValues(i).ToString()
            Next
            DrawBoxedString(sender, e, (UBound(chrValues) + 1), IItem.xPos, IItem.yPos, IItem.BoxWidth, IItem.BoxHeight, strValues, IItem.ItemFont, IItem.xOffset, IItem.yOffset)
        End If

    End Sub

    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: PrintAmountString
    '   DESCRIPTION: ' Sub to convert rupee amount digits to string and print them in boxes
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. IItem: CInstrumentItem : The CInstrumentItem object that needs to be processed for printing
    '               2. sender: pdoc_PrintPage eventhandler parameter. Not used currently. May be used in the future
    '               3. e: Handle needed for printing 
    '*****************************************************************************************
    Private Sub PrintAmountString(ByVal IItem As CInstrumentItem, ByVal sender As Object, ByVal e As System.Drawing.Printing.PrintPageEventArgs)
        Dim chrValues As Char()
        Dim strNumeric As String()
        Dim strWeights As String()
        Dim i As Integer
        chrValues = IItem.Data.ToCharArray
        If IsArray(chrValues) Then
            ReDim strNumeric(UBound(chrValues))
            ReDim strWeights(UBound(chrValues))
            For i = LBound(chrValues) To UBound(chrValues)
                'Get the string values for the digits
                strNumeric(i) = GetStringForDigit(chrValues(i))
                'Get the weights of the individual digits
                strWeights(i) = GetWeightForDigit(UBound(chrValues) - i)
            Next
            'Draw the first row of boxes for the string values of the digits
            DrawBoxedString(sender, e, UBound(chrValues) + 1, IItem.xPos, IItem.yPos, IItem.BoxWidth, IItem.BoxHeight, strNumeric, IItem.ItemFont, IItem.xOffset, IItem.yOffset)

            'Draw the first row of boxes for the weights of the digits
            DrawBoxedString(sender, e, UBound(chrValues) + 1, IItem.xPos, (IItem.yPos + IItem.BoxHeight), IItem.BoxWidth, IItem.BoxHeight, strWeights, IItem.ItemFont, IItem.xOffset, IItem.yOffset)
        End If
    End Sub

    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: GetStringForDigit
    '   DESCRIPTION: Funtion that returns the string for a digit 
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. chrN : Char : The Char representation of the digit to be converted
    '   RETURN TYPE: String: The string representation of a digit
    '*****************************************************************************************
    Private Function GetStringForDigit(ByVal chrN As Char) As String
        Select Case chrN

            Case "0"
                GetStringForDigit = "ZERO"
            Case "1"
                GetStringForDigit = "ONE"
            Case "2"
                GetStringForDigit = "TWO"
            Case "3"
                GetStringForDigit = "THREE"
            Case "4"
                GetStringForDigit = "FOUR"
            Case "5"
                GetStringForDigit = "FIVE"
            Case "6"
                GetStringForDigit = "SIX"
            Case "7"
                GetStringForDigit = "SEVEN"
            Case "8"
                GetStringForDigit = "EIGHT"
            Case "9"
                GetStringForDigit = "NINE"
        End Select
    End Function

    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: GetWeightForDigit
    '   DESCRIPTION: Function that returns the weight for a number based on the position provided
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. nPos : Integer : The weight(position) of a digit in a multidigit numeric value
    '   RETURN TYPE: String: The string representation of the weight of the digit
    '*****************************************************************************************
    Private Function GetWeightForDigit(ByVal nPos As Integer) As String
        Select Case nPos
            Case 0
                GetWeightForDigit = "UNITS"
            Case 1
                GetWeightForDigit = "TENS"
            Case 2
                GetWeightForDigit = "HUNDS"
            Case 3
                GetWeightForDigit = "THDS"
            Case 4
                GetWeightForDigit = "T'THDS"
            Case 5
                GetWeightForDigit = "LAKHS"
            Case 6
                GetWeightForDigit = "T'LAKHS"
            Case 7
                GetWeightForDigit = "CRORES"
            Case 8
                GetWeightForDigit = "T'CRRS"
            Case 9
                GetWeightForDigit = "H'CRRS"
        End Select
    End Function

    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: DrawBoxedString
    '   DESCRIPTION: Draws a series of boxes and writes strings into the boxes
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. sender: pdoc_PrintPage eventhandler parameter. Not used currently. May be used in the future
    '               2. e: Handle needed for printing 
    '               3. x  : Integer : The x position of the box
    '               4. y  : Integer: The y position of the box
    '               5. width  : Integer : The width of the box
    '               6. height  : Integer : The height of the box
    '               7. sData  : String() : the String array that needs individual strings to be printed in a separate box
    '               8. BoxFont : Font : The font to be used for the strings
    '               9. nStrXOffset  : Integer : The horizontal offset from the left of a box where the string should be written
    '               10. nStrYOffset : Integer :The vertical offset from the top of a box where the string should be written

    '*****************************************************************************************
    Private Sub DrawBoxedString(ByVal sender As Object, ByVal e As System.Drawing.Printing.PrintPageEventArgs, ByVal nRectCount As Integer, ByVal x As Integer, ByVal y As Integer, ByVal width As Integer, ByVal height As Integer, ByVal sData As String(), ByVal BoxFont As Font, ByVal nStrXOffset As Integer, ByVal nStrYOffset As Integer)
        Dim Recs As RectangleF()
        ReDim Recs(nRectCount)
        Dim i = 0
        For i = 0 To nRectCount - 1
            Recs(i) = New RectangleF((x + (i * width)), y, width, height)
            e.Graphics.DrawString(sData(i), BoxFont, Brushes.Black, (x + (i * width) + nStrXOffset), y + nStrYOffset)
        Next
        e.Graphics.DrawRectangles(Pens.Black, Recs)
    End Sub
