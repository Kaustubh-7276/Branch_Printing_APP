    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: GetPaiseString
    '   DESCRIPTION: Funtion that returns the string for the amount in paise 
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. chrValues : Char() : The Char representation of the paise amount to be converted
    '   RETURN TYPE: String: The string string for the amount in paise 
    '*****************************************************************************************
    Public Function GetPaiseString(ByVal chrValues As Char()) As String
        Dim i As Integer

        If IsArray(chrValues) Then
            Select Case chrValues(0)
                Case "0"
                    If chrValues(1) = "0" Then
                        GetPaiseString = "ZERO"
                    Else
                        GetPaiseString = GetStringForDigit(chrValues(1))
                    End If
                Case "1"
                    Select Case chrValues(1)
                        Case "0"
                            GetPaiseString = "TEN"
                        Case "1"
                            GetPaiseString = "ELEVEN"
                        Case "2"
                            GetPaiseString = "TWELVE"
                        Case "3"
                            GetPaiseString = "THIRTEEN"
                        Case "4"
                            GetPaiseString = "FOURTEEN"
                        Case "5"
                            GetPaiseString = "FIFTEEN"
                        Case "6"
                            GetPaiseString = "SIXTEEN"
                        Case "7"
                            GetPaiseString = "SEVENTEEN"
                        Case "8"
                            GetPaiseString = "EIGHTEEN"
                        Case "9"
                            GetPaiseString = "NINETEEN"
                    End Select
                Case Else
                    ' IF value in multiples of 10
                    If chrValues(1) = "0" Then
                        GetPaiseString = GetTensString(chrValues(0))
                    Else
                        GetPaiseString = GetTensString(chrValues(0)) + " " + GetStringForDigit(chrValues(1))
                    End If

            End Select


        End If

    End Function
    '*****************************************************************************************
    '*****************************************************************************************
    '   METHOD NAME: GetTensString
    '   DESCRIPTION: Funtion that returns the string for the tens digit of the amount in paise 
    '   SCOPE:       Private
    '   AUTHOR:      Amal Savle
    '   CREATED ON:  02 May 2005
    '*****************************************************************************************
    '   PARAMETERS: 1. chr : Char : The Char representation of the digit to be converted
    '   RETURN TYPE: String: The string representation for the tens digit of the amount in paise 
    '*****************************************************************************************
    Private Function GetTensString(ByVal chr As Char) As String
        Select Case chr
            Case "2"
                GetTensString = "TWENTY"
            Case "3"
                GetTensString = "THIRTY"
            Case "4"
                GetTensString = "FORTY"
            Case "5"
                GetTensString = "FIFTY"
            Case "6"
                GetTensString = "SIXTY"
            Case "7"
                GetTensString = "SEVENTY"
            Case "8"
                GetTensString = "EIGHTY"
            Case "9"
                GetTensString = "NINETY"
        End Select
    End Function

