using System.Text;

namespace Branch_Printing_APP.LogHelper
{
    public static class FileLogger
    {
        private static readonly object _lock = new object();

        private static readonly string LogDirectory =
          Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Logs");

        private static string GetLogFile()
        {
            return Path.Combine(LogDirectory,
              "Log_" + DateTime.Now.ToString("yyyyMMdd") + ".log");
        }

        private static void EnsureDirectory()
        {
            if (!Directory.Exists(LogDirectory))
                Directory.CreateDirectory(LogDirectory);
        }

        private static void Write(string level, string message)
        {
            try
            {
                EnsureDirectory();

                string log = $"{DateTime.Now:yyyy-MM-dd HH:mm:ss.fff} [{level}] {message}";

                lock (_lock)
                {
                    using (var fs = new FileStream(GetLogFile(), FileMode.Append, FileAccess.Write, FileShare.Read))
                    using (var sw = new StreamWriter(fs, Encoding.UTF8))
                    {
                        sw.WriteLine(log);
                    }
                }
            }
            catch
            {
                // Never throw from logger
            }
        }

        public static void Info(string msg) => Write("INFO", msg);
        public static void Warn(string msg) => Write("WARN", msg);
        public static void Error(string msg) => Write("ERROR", msg);
        public static void Error(string msg, Exception ex) => Write("ERROR", msg + " | " + ex);
    }
}
