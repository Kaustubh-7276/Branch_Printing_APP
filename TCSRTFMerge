        // =========================
        // 🔹 MERGE DOCUMENT CORE
        // =========================
        private RTFMergeDocumentResult RTFMergeDocument(
        TCSRTFDocument doc,
        XmlNode xmlRXSection,
        ref string StartRow,
        ref int nEndLine)
        {
            var templateFields = doc.GetGroupsByCommand("\\field");

            RTFMergeDocumentResult result = RTFMergeDocumentResult.NoMerge;

            TCSLineCheck lineCheck = new TCSLineCheck();
            lineCheck.StartLine = Convert.ToInt32(StartRow);

            XmlNode usedAttr = xmlRXSection.OwnerDocument.CreateAttribute(MERGER_FIELD_USED);
            usedAttr.InnerText = "True";

            foreach (RTFNode templateField in templateFields)
            {
                RTFFieldGroup fieldGroup = new RTFFieldGroup((RTFGroup)templateField);

                string instruction = fieldGroup.FieldInstruction.Trim();

                if (instruction.Length > 0)
                {
                    fieldGroup.FieldResult = "";

                    XmlNodeList messageFields = null;
                    bool valid = false;

                    try
                    {
                        instruction = XPathValidator.Validate(instruction);
                        messageFields = xmlRXSection.SelectNodes(instruction);
                        valid = true;
                    }
                    catch
                    {
                        valid = false;
                    }

                    if (lineCheck.Check(instruction) && valid)
                    {
                        foreach (XmlNode field in messageFields)
                        {
                            if (IsXMLNodePrintable(field))
                            {
                                fieldGroup.FieldResult = field.InnerText;

                                result = RTFMergeDocumentResult.Merged;
                                StartRow = lineCheck.LineNo.ToString();
                                nEndLine = lineCheck.LineNo;

                                break;
                            }
                        }
                    }
                }
            }

            return result;
        }

        // =========================
        // 🔹 PRINTABLE CHECK
        // =========================
        private bool IsXMLNodePrintable(XmlNode node)
        {
            if (node.ChildNodes.Count == 1)
                return node.FirstChild.NodeType == XmlNodeType.Text;

            if (node.ChildNodes.Count == 0)
                return true;

            return false;
        }
