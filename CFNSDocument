    Public Function createReturnDocument() As CFNSComponentDocument
        Dim oReturnDocument As New CFNSComponentDocument()

        ' Copy header
        oReturnDocument.setHeader(Me.header)

        ' Copy persistant nodes to new document
        Dim oBodyNodes As Xml.XmlNodeList
        Dim oBodyNode As Xml.XmlNode

        oBodyNodes = Me.body.SelectNodes("*[@persist='True']")

        For Each oBodyNode In oBodyNodes
            oReturnDocument.body.AppendChild(oReturnDocument.OwnerDocument.ImportNode(oBodyNode, True))
        Next
        Return oReturnDocument

    End Function

