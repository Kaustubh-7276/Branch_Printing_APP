    Private Function ParseTwenty(ByVal FromValue As String) As String

        Dim Word As String = ""
        Dim FirstValue As Integer
        Dim SecondValue As Integer
        SecondValue = Convert.ToInt32(FromValue) Mod 10
        FirstValue = (Convert.ToInt32(FromValue) - SecondValue)
        Select Case (FirstValue)
