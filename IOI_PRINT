    Private Function ParseNumber2Words(ByVal NumberValue As String) As String

        Dim FormattedValue As String
        Dim NumberMain As String
        Dim DecimalMain As String
        Dim NumberSub As String
        Dim MainArray() As String
        Dim NumberMainArray() As String
        Dim NumberMainArrayLen As Integer

        Dim counter As Integer
        Dim location As Integer
        Dim Word As String = ""
        Dim AndWord As String = ""
        AddAndInInteger = False

        FormattedValue = NumberValue
        MainArray = FormattedValue.Split(Convert.ToChar("."))

        If (MainArray.Length <= 2) Then
            If (MainArray.Length = 1) Then
                AddAndInInteger = True
            ElseIf (MainArray(1) = "") Then
                AddAndInInteger = True
            ElseIf (Convert.ToInt64(MainArray(1)) < 1) Then
                AddAndInInteger = True
            End If
            NumberMain = MainArray(0)
            NumberMain = MakeINR(NumberMain)
            NumberMain = Left(NumberMain, NumberMain.Length - 3)
            NumberMainArray = NumberMain.Split(Convert.ToChar(","))
            NumberMainArrayLen = NumberMainArray.Length
            For counter = NumberMainArrayLen - 1 To 0 Step -1
                location = (NumberMainArrayLen - 1) - counter
                If (Convert.ToInt64(NumberMainArray(counter)) > 0) Then
                    If (location = 0) Then
                        Word = MakeWord(NumberMainArray(counter)) + Word
                    Else
                        Word = MakeWord(NumberMainArray(counter)) + MakeQualifier(location) + Word
                    End If
                End If
            Next
            If (AddAndInInteger = False) Then
                If (Word <> "") Then
                    AndWord = "and "
                End If
                DecimalMain = MainArray(1)
                If (DecimalMain.Length = 1) Then
                    DecimalMain += "0"
                End If
                Word += AndWord + MakeQualifier(-1) + MakeWord(DecimalMain)
            End If
            Return Word
        End If

    End Function
    Private Function MakeWord(ByVal FromValue As String) As String

        Dim sDefaultCurrency As String = "INR"
        Dim Word As String = ""
        Dim AndWord As String = "and "
        Dim Valuelength As Integer = FromValue.Length
        Dim IntValue As Long = Convert.ToInt64(FromValue)
        Dim StoreAndLocation As Boolean
        If (Valuelength < 4) Then
            If (Valuelength = 3) Then
                If (Convert.ToInt32(FromValue.Substring(0, 1)) > 0) Then
                    Word += ParseOne(FromValue.Substring(0, 1))
                    Word += MakeQualifier(0)
                    If (AddAndInInteger And Convert.ToInt32(FromValue.Substring(1, 2)) > 0) Then
                        Word += AndWord
                    End If
                End If
                IntValue = Convert.ToInt64(FromValue.Substring(1, 2))
                FromValue = FromValue.Substring(1, 2)
            End If
            If (IntValue >= 1 And IntValue <= 9) Then
                If (FromValue.Length > 1) Then
                    FromValue = FromValue.Substring(1, 1)
                End If
                Word += ParseOne(FromValue)
            ElseIf (IntValue >= 10 And IntValue <= 19) Then
                Word += ParseTen(FromValue)
            ElseIf (IntValue >= 20 And IntValue <= 99) Then
                Word += ParseTwenty(FromValue)
            End If
        Else
            StoreAndLocation = AddAndInInteger
            Word += ParseNumber2Words(FromValue)
            AddAndInInteger = StoreAndLocation
        End If
        Return Word

    End Function

