        Dim IntegerLength As Integer
        Dim IntegerPart As String
        Dim OutValue As String
        Dim sign As Boolean = False

        If WholeValue.Substring(0, 1) = "+" Or WholeValue.Substring(0, 1) = "-" Then
            sign = True
            NumberValue = WholeValue.Substring(1)
        Else
            NumberValue = WholeValue
        End If

        MainArray = NumberValue.Split(Convert.ToChar("."))
        If IsArray(MainArray) Then
            If MainArray.Length < 2 Then
                ReDim Preserve MainArray(1)
                MainArray(1) = "00"
            End If
        End If

        IntegerPart = MainArray(0)
        IntegerLength = IntegerPart.Length
        If IntegerLength > 7 Then
            IntegerPart = String.Concat(IntegerPart.Substring(0, IntegerLength - 7), ",", IntegerPart.Substring(IntegerLength - 7, 2), ",", IntegerPart.Substring(IntegerLength - 5, 2), ",", IntegerPart.Substring(IntegerLength - 3, 3))
        ElseIf IntegerLength > 5 Then
            IntegerPart = String.Concat(IntegerPart.Substring(0, IntegerLength - 5), ",", IntegerPart.Substring(IntegerLength - 5, 2), ",", IntegerPart.Substring(IntegerLength - 3, 3))
        ElseIf IntegerLength > 3 Then
            IntegerPart = String.Concat(IntegerPart.Substring(0, IntegerLength - 3), ",", IntegerPart.Substring(IntegerLength - 3, 3))
        End If

        If MainArray.Length > 1 Then
            OutValue = IntegerPart + "." + MainArray(1).PadRight(2, "0").ToString
        Else
            OutValue = IntegerPart
        End If

        If sign Then
            OutValue = WholeValue.Substring(0, 1) + OutValue
        End If
        Return OutValue

    End Function

    Private Function SplitAmtString(ByVal amntstrng As String) As String()
        Dim words() As String = amntstrng.Split(" ")
        Dim retstring(2) As String
        Dim len As Integer = 0
        Dim i As Integer = 0
        Dim j As Integer = 0

        retstring(0) = ""
        retstring(1) = ""

        For i = 0 To words.Length - 1
            retstring(0) = retstring(0) + words(i) + " "
            len = len + words(i).Length

            If len >= 70 Then
                i = i + 1
                GoTo OUTFOR
            End If
        Next
OUTFOR:
        For j = i To words.Length - 1
            retstring(1) = retstring(1) + words(j) + " "
        Next

        Return retstring
    End Function


End Class
