        Public Sub PrinterSetting()
            Try
                oPD = New PrintDocument()
                oPD.PrinterSettings = New PrinterSettings()
                oRichTextBoxPrintCtrl = New RichTextBoxPrintCtrl.RichTextBoxPrintCtrl()
                PrinterObject = New SPageSettings()
                PrinterObject.Orientation = 1
                oPD.DefaultPageSettings.Landscape = False
                bInitSuccess = True


            Catch ex As Exception
                bInitSuccess = False
                Throw New System.Exception(ex.Message)
            Finally
                If (bInitSuccess = False) Then
                    oPD.Dispose()
                    oRichTextBoxPrintCtrl.Dispose()
                End If



            End Try

        End Sub
        Public Sub StartPrinterCmd()

            Dim jobId$

            docinfo1.pDocName = "Test"
            docinfo1.pOutputFile = vbNullString
            docinfo1.pDataType = vbNullString

            jobId = StartDocPrinter(hPrinter1, 1, docinfo1)
            Call StartPagePrinter(hPrinter1)

        End Sub

        Public Sub EndPrinterCmd()
            Call EndPagePrinter(hPrinter1)
            Call EndDocPrinter(hPrinter1)
            Call ClosePrinter(hPrinter1)
        End Sub
        Public Sub ResetPrinter()

            Dim EscSeq$
            Dim written&

            Call StartPrinterCmd()
            EscSeq$ = Chr(18)
            Call WritePrinter(hPrinter1, EscSeq$, Len(EscSeq$), written)

            Call EndPrinterCmd()
        End Sub

