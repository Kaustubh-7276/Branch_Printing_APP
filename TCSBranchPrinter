            End Try



        End Sub




        Public Sub InitialisePrinter(ByVal sPrinterName As String)


            Try


                Dim nCount As Integer
                Dim sErrorMsg As String
                Dim sCommands() As String
                Dim Eseq As String = ""
                Dim written&
                Try
                    sCommands = Split(sPrinterName, ";")
                Catch ex As Exception
                    sCommands = Split(sPrinterName, "")
                End Try

                sPrinterName = sCommands(0)
                Dim sPrinters As String
                oPD.PrinterSettings.PrinterName = sPrinterName
                If OpenPrinter(oPD.PrinterSettings.PrinterName, hPrinter1, 0) = 0 Then
                Else
                    Call StartPrinterCmd()

                    If sCommands(1) = "17" Then
                        Eseq$ = Chr(18)
                        Call WritePrinter(hPrinter1, Eseq$, Len(Eseq$), written)

                        Eseq$ = Chr(15)
                        Call WritePrinter(hPrinter1, Eseq$, Len(Eseq$), written)
                        PrinterObject.Orientation = 2
                        oPD.PrinterSettings.DefaultPageSettings.PaperSize = New PaperSize("LedgerForm", "1700", "1100")
                        oPD.PrinterSettings.DefaultPageSettings.Margins = New Margins(0, 0, 0, 0)
                        oPD.DefaultPageSettings.PaperSize = New PaperSize("LedgerForm", "1700", "1100")
                        oPD.DefaultPageSettings.Margins = New Margins(0, 0, 0, 0)

                    End If

                    If sCommands(1) = "12" Then
                        Eseq$ = Chr(18)
                        Call WritePrinter(hPrinter1, Eseq$, Len(Eseq$), written)
                        Eseq$ = Chr(27) & Chr(58)
                        Call WritePrinter(hPrinter1, Eseq$, Len(Eseq$), written)
                        PrinterObject.Orientation = 2
                        oPD.PrinterSettings.DefaultPageSettings.PaperSize = New PaperSize("LetterForm", "1100", "850")
                        oPD.PrinterSettings.DefaultPageSettings.Margins = New Margins(0, 0, 0, 0)
                        oPD.DefaultPageSettings.PaperSize = New PaperSize("LetterForm", "1100", "850")
                        oPD.DefaultPageSettings.Margins = New Margins(0, 0, 0, 0)
                    End If

                    oPD.PrinterSettings.DefaultPageSettings.Margins = New Margins(0, 0, 0, 0)
                    oPD.DefaultPageSettings.Margins = New Margins(0, 0, 0, 0)

                    Call EndPrinterCmd()
                End If
                If sPrinterName <> "" Then
                    sErrorMsg = "The Printer " & sPrinterName & " could not be initialised. "
                    If nCount = 0 Then
                        sErrorMsg = sErrorMsg & "There are no printers configured on this server."
                    Else
                        sErrorMsg = sErrorMsg & "Bancslink printer queue settings do not match any printers configured on the Bancslink server. The printers on server: " & sPrinters & ". An administrator must either change the printer names on the BancsLink server or reconfigure the printer in the BancsLink printer queue administration."
                    End If
                Else
                End If
            Catch ex As Exception
            Finally
               
            End Try
        End Sub

